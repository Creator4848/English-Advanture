# English Adventure — Environment Variables

# ── Backend (Python FastAPI) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/english_adventure
REDIS_URL=redis://localhost:6379/0

# OpenAI (required for AI Speaking Partner + Whisper)
OPENAI_API_KEY=sk-...

# YouTube Data API v3 (required for /api/videos/sync)
YOUTUBE_API_KEY=AIza...
# Optional – sync from a specific channel automatically
YOUTUBE_CHANNEL_ID=UCxxxxxx

# JWT secret (change in production!)
JWT_SECRET=change-me-to-a-long-random-string


# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Base URL of the FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# WebSocket URL for Speaking Club
NEXT_PUBLIC_WS_URL=ws://localhost:8000
